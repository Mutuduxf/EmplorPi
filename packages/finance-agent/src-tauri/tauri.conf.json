{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config/packages/schema/schema.json",
  "productName": "My Agent",
  "version": "0.1.0",
  "identifier": "com.myagent.app",
  "build": {
    "frontendDist": "../src-agent",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "",
    "beforeDevCommand": ""
  },
  "app": {
    "windows": [
      {
        "title": "My Agent",
        "width": 900,
        "height": 700
      }
    ]
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ],
    "externalBin": ["binaries/agent-sidecar"],
    "resources": ["../skills/"]
  },
  "plugins": {}
}
