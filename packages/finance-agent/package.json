	},
	"devDependencies": {
		"@tauri-apps/cli": "^2",
		"@types/node": "^22",
		"@types/react": "18.3.31",
		"@types/react-dom": "18.3.7",
		"@vitejs/plugin-react": "^4",
		"react": "18.3.1",
		"react-dom": "18.3.1",
		"tsx": "^4.0.0",
		"typescript": "5.9.3",
		"vite": "^6"
	}
